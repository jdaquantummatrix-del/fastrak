{
  "name": "project-kenny",
  "version": "0.1.0",
  "private": true,
  "description": "Web rebuild of Kennard's fastrak (FoxPro) distribution system",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "node scripts/migrate.mjs",
    "db:import": "node scripts/import-fastrak.mjs",
    "db:seed": "node scripts/seed-admin.mjs",
    "db:setup": "npm run db:migrate && npm run db:import && npm run db:seed",
    "demo:load": "tsx scripts/demo-load.ts",
    "demo:wipe": "tsx scripts/demo-wipe.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "next": "^15.1.6",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  }
}
