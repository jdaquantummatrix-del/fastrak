# ─────────────────────────────────────────────────────────────────────────────
# fastrak — environment variables
#
# LOCAL DEV (`npm run dev`):
#   Leave DATABASE_URL UNSET. The app falls back to a local PGlite store
#   (./.pglite) so you need no running database. Just set SESSION_SECRET and the
#   ADMIN_* values, then run `npm run db:seed` once.
#
# PRODUCTION / DOCKER (`docker compose up -d --build`):
#   docker-compose injects DATABASE_URL (pointing at the `db` service) into the
#   app container for you — you do NOT set it here. Compose reads this file only
#   for the secrets below (${...} substitution).
# ─────────────────────────────────────────────────────────────────────────────

# Signs the session cookie (HMAC-SHA256). Generate a strong value:
#   openssl rand -hex 32
SESSION_SECRET=

# Password for the Postgres `postgres` role inside the Docker database.
POSTGRES_PASSWORD=postgres

# The first admin user, created automatically on container start (idempotent).
# Change ADMIN_PASSWORD before the first deploy, or reset it from the UI after.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Set to "true" ONLY when the app is served over HTTPS (behind a TLS proxy like
# Caddy). Leave it off/unset for a plain-HTTP deployment, or logins won't stick
# (the browser drops a "secure" cookie sent over http).
COOKIE_SECURE=false
