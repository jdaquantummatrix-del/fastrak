DATABASE_URL=postgres://postgres:postgres@localhost:5432/projectkenny

# S12 Auth (simple login gate). The single shared password that lets a user in.
# Set this to a strong value in every deployment; a blank value disables login
# (the gate then rejects everyone, since an empty password never matches).
APP_PASSWORD=changeme

# Optional: an independent secret used to sign the session cookie. If unset, the
# session is signed with APP_PASSWORD. Set a separate long random value in
# production so rotating the login password doesn't have to invalidate the key.
# SESSION_SECRET=
